---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogCard from '@/components/BlogCard.astro';
import NewsletterForm from '@/components/NewsletterForm.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Cloud & DevOps Engineer"
  description="Cloud & DevOps engineer writing about AWS, AI, and the future of infrastructure engineering."
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-white/[0.08]">
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,107,53,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(255,107,53,0.05)_1px,transparent_1px)] bg-[size:48px_48px]"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[320px] bg-accent/10 blur-[120px] pointer-events-none"></div>
    <div class="relative max-w-5xl mx-auto px-6 py-32 text-center">
      <span class="inline-block font-mono text-xs tracking-[3px] uppercase text-accent bg-accent/10 border border-accent/20 rounded-full px-4 py-2 mb-8">
        Cloud &middot; DevOps &middot; AI
      </span>
      <h1 class="font-serif text-5xl md:text-7xl font-black leading-[1.05] text-white mb-6">
        Hi, I&apos;m <span class="text-accent italic">Shantayya</span>
      </h1>
      <p class="text-muted text-lg md:text-xl max-w-xl mx-auto mb-10 leading-relaxed font-light italic">
        I write about AWS, DevOps, and AI — helping engineers navigate the rapidly evolving infrastructure landscape.
      </p>
      <div class="flex items-center justify-center gap-4 flex-wrap">
        <a href="/blog"
           class="bg-accent hover:bg-accent/90 text-white font-mono text-sm font-medium px-7 py-3 rounded-xl transition-colors">
          Read the Blog
        </a>
        <a href="/about"
           class="border border-white/15 text-ink hover:border-white/30 font-mono text-sm px-7 py-3 rounded-xl transition-colors">
          About Me
        </a>
      </div>
    </div>
  </section>

  <!-- Recent Posts -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <div class="flex items-center justify-between mb-10">
      <h2 class="font-serif text-3xl font-bold text-white">Latest Posts</h2>
      <a href="/blog" class="font-mono text-sm text-accent hover:underline">View all &rarr;</a>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {recentPosts.map(post => (
        <BlogCard
          title={post.data.title}
          excerpt={post.data.excerpt}
          date={post.data.date}
          tags={post.data.tags}
          readTime={post.data.readTime}
          slug={post.slug}
          featured={post.data.featured}
        />
      ))}
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="border-t border-white/[0.08] bg-surface">
    <div class="max-w-2xl mx-auto px-6 py-20 text-center">
      <h2 class="font-serif text-3xl font-bold text-white mb-4">Stay in the Loop</h2>
      <p class="text-muted mb-8 leading-relaxed">
        Get notified when I publish new articles on AWS, DevOps, and AI engineering.
        No spam &mdash; just signal.
      </p>
      <NewsletterForm />
    </div>
  </section>
</BaseLayout>
