---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title:       string;
  description: string;
  date:        Date;
  tags:        string[];
  readTime:    string;
  author:      string;
  image?:      string;
}

const { title, description, date, tags, readTime, author, image } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout title={title} description={description} image={image} type="article" publishedDate={date}>
  <div class="max-w-3xl mx-auto px-6 py-16">

    <!-- Hero image -->
    {image && (
      <div class="mb-10 rounded-2xl overflow-hidden border border-white/[0.08]">
        <img src={image} alt={title} class="w-full h-auto block" loading="eager" />
      </div>
    )}

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 mb-6">
      {tags.map(tag => (
        <span class="font-mono text-xs text-teal bg-teal/10 border border-teal/20 rounded-full px-3 py-1">
          {tag}
        </span>
      ))}
    </div>

    <!-- Title -->
    <h1 class="font-serif text-4xl md:text-5xl font-black leading-[1.08] text-white mb-6">
      {title}
    </h1>

    <!-- Meta bar -->
    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 font-mono text-sm text-muted
                mb-12 pb-8 border-b border-white/[0.08]">
      <span>{author}</span>
      <span class="hidden sm:block w-1 h-1 rounded-full bg-muted"></span>
      <span>{formattedDate}</span>
      <span class="hidden sm:block w-1 h-1 rounded-full bg-muted"></span>
      <span>{readTime}</span>
    </div>

    <!-- Prose content -->
    <article class="prose prose-blog prose-lg max-w-none">
      <slot />
    </article>

    <!-- Back link -->
    <div class="mt-16 pt-8 border-t border-white/[0.08]">
      <a href="/blog" class="font-mono text-sm text-muted hover:text-accent transition-colors">
        &larr; Back to all posts
      </a>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .mermaid {
    display: flex;
    justify-content: center;
    overflow-x: auto;
    margin: 2rem 0;
    padding: 1rem;
    background: #1c1c1c;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.75rem;
  }
  .mermaid svg {
    max-width: 100%;
    height: auto;
  }
</style>

<script type="module" is:inline>
  // Astro/Shiki renders ```mermaid fences as <pre data-language="mermaid"><code>...</code></pre>
  // (NOT <code class="language-mermaid"> — that selector was the bug in the earlier attempt,
  // which silently matched nothing and left raw highlighted syntax on screen).
  const blocks = document.querySelectorAll('pre[data-language="mermaid"]');

  if (blocks.length) {
    try {
      const { default: mermaid } = await import(
        'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs'
      );

      mermaid.initialize({
        startOnLoad: false,
        theme: 'dark',
        themeVariables: {
          fontFamily: '"JetBrains Mono", monospace',
          fontSize: '18px',
        },
        flowchart: {
          padding: 12,
        },
      });

      const nodes = [];
      blocks.forEach(pre => {
        const code = pre.querySelector('code');
        const div = document.createElement('div');
        div.className = 'mermaid';
        div.textContent = code?.textContent ?? '';
        pre.replaceWith(div);
        nodes.push(div);
      });

      // suppressErrors: a bad diagram renders as an inline error instead of
      // aborting the whole batch (and never touches the rest of the page).
      await mermaid.run({ nodes, suppressErrors: true });
    } catch (err) {
      // CDN unreachable, parse failure, etc. — the original Shiki code block
      // is already gone, but the rest of the page is untouched either way.
      console.error('Mermaid rendering failed:', err);
    }
  }
</script>
