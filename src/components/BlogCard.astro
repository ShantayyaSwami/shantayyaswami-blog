---
interface Props {
  title:    string;
  excerpt:  string;
  date:     Date;
  tags:     string[];
  readTime: string;
  slug:     string;
  featured?: boolean;
}

const { title, excerpt, date, tags, readTime, slug, featured } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<article class="group relative bg-card border border-white/[0.08] rounded-2xl p-6
                hover:border-accent/30 transition-all duration-300 hover:-translate-y-1
                flex flex-col gap-4">
  {featured && (
    <span class="font-mono text-[10px] tracking-[2px] uppercase text-accent
                 bg-accent/10 border border-accent/20 rounded-full px-3 py-1 self-start">
      Featured
    </span>
  )}

  <div class="flex flex-wrap gap-2">
    {tags.map(tag => (
      <span class="font-mono text-[11px] text-teal bg-teal/10 border border-teal/20 rounded-full px-2.5 py-0.5">
        {tag}
      </span>
    ))}
  </div>

  <h2 class="font-serif text-xl font-bold text-white group-hover:text-accent transition-colors leading-snug">
    <a href={`/blog/${slug}`} class="after:absolute after:inset-0">{title}</a>
  </h2>

  <p class="text-muted text-sm leading-relaxed flex-1">{excerpt}</p>

  <div class="flex items-center gap-3 font-mono text-xs text-muted pt-2 border-t border-white/[0.06]">
    <span>{formattedDate}</span>
    <span class="w-1 h-1 rounded-full bg-muted inline-block flex-shrink-0"></span>
    <span>{readTime}</span>
  </div>
</article>
